    cntChart('chartCntC-'+key,lbl,M.map(function(d){return d.cnt-d.dC;}),M.map(function(d){return d.dC;}),'#B84040','잔금미납(누적)','cntHintC-'+key);
    arpChart('chartArp-'+key, lbl,M.map(function(d){return Math.round(d.aT/10000);}),M.map(function(d){return Math.round(d.pW/10000);}),'#F0997B','#C8715A');
    arpChart('chartArpC-'+key,lbl,M.map(function(d){return Math.round(d.aT/10000);}),M.map(function(d){return Math.round(d.pC/10000);}),'#4A7FB5','#2D5F85');

    var th='<table class="summary"><thead><tr>'
      +'<th>월</th><th>동의수</th><th>건수</th><th>예약금건수비중</th>'
      +'<th class="grp-divide">ARP</th><th>월내회수</th><th>월내잔액</th><th>월내전환율(금액)</th><th>잔금미납고객비중(월내)</th>'
      +'<th class="grp-divide">누적회수</th><th>누적잔액</th><th>누적전환율(금액)</th><th>잔금미납고객비중(누적)</th>'
      +'</tr></thead><tbody>';
    var n = M.length;
    var arrCntShare=[], arrDepOnlyW=[], arrRateAmtW=[], arrRateAmtC=[], arrDepOnlyC=[];
    M.forEach(function(d){
      var remainW=d.aT-d.pW;
      var remainC=d.aT-d.pC;
      var depOnlyW=(d.dW/d.cnt*100).toFixed(1);
      var depOnlyC=(d.dC/d.cnt*100).toFixed(1);
      var cntShare=(d.cnt/d.cs*100).toFixed(1);
      var rateAmtW=d.aT?(d.pW/d.aT*100).toFixed(1):'0.0';
      var rateAmtC=d.aT?(d.pC/d.aT*100).toFixed(1):'0.0';
      arrCntShare.push(parseFloat(cntShare));
      arrDepOnlyW.push(parseFloat(depOnlyW));
      arrRateAmtW.push(parseFloat(rateAmtW));
      arrRateAmtC.push(parseFloat(rateAmtC));
      arrDepOnlyC.push(parseFloat(depOnlyC));
      th+='<tr>'
        +'<td>'+d.m+'</td><td>'+d.cs+'건</td><td>'+d.cnt+'건</td><td>'+cntShare+'%</td>'
        +'<td class="grp-divide">'+f2(d.aT)+'</td><td>'+f2(d.pW)+'</td><td>'+f2(remainW)+'</td><td>'+rateAmtW+'%</td><td>'+depOnlyW+'% ('+d.dW+'건)</td>'
        +'<td class="grp-divide">'+f2(d.pC)+'</td><td>'+f2(remainC)+'</td><td>'+rateAmtC+'%</td><td>'+depOnlyC+'% ('+d.dC+'건)</td>'
        +'</tr>';
    });
    var totalCntShare=(tC/tCS*100).toFixed(1);
    var totalDepOnlyW=(tDW/tC*100).toFixed(1);
    var totalDepOnlyC=(tDC/tC*100).toFixed(1);
    var totalRateAmtW=(tPW/tA*100).toFixed(1);
    var totalRateAmtC=(tPC/tA*100).toFixed(1);
    th+='<tr class="total-row">'
      +'<td>합계</td><td>'+tCS+'건</td><td>'+tC+'건</td><td>'+totalCntShare+'%</td>'
      +'<td class="grp-divide">'+f2(tA)+'</td><td>'+f2(tPW)+'</td><td>'+f2(tA-tPW)+'</td><td>'+totalRateAmtW+'%</td><td>'+totalDepOnlyW+'% ('+tDW+'건)</td>'
      +'<td class="grp-divide">'+f2(tPC)+'</td><td>'+f2(tA-tPC)+'</td><td>'+totalRateAmtC+'%</td><td>'+totalDepOnlyC+'% ('+tDC+'건)</td>'
      +'</tr>';
    function avgArr(a){return a.reduce(function(s,v){return s+v;},0)/a.length;}
    var avgCS=tCS/n, avgCnt=tC/n, avgArp=tA/n, avgPW=tPW/n, avgRemainW=(tA-tPW)/n, avgPC=tPC/n, avgRemainC=(tA-tPC)/n;
    var avgDW=tDW/n, avgDC=tDC/n;
    th+='<tr class="avg-row">'
      +'<td>평균</td><td>'+avgCS.toFixed(1)+'건</td><td>'+avgCnt.toFixed(1)+'건</td><td>'+avgArr(arrCntShare).toFixed(1)+'%</td>'
      +'<td class="grp-divide">'+f2(avgArp)+'</td><td>'+f2(avgPW)+'</td><td>'+f2(avgRemainW)+'</td><td>'+avgArr(arrRateAmtW).toFixed(1)+'%</td><td>'+avgArr(arrDepOnlyW).toFixed(1)+'% ('+avgDW.toFixed(1)+'건)</td>'
      +'<td class="grp-divide">'+f2(avgPC)+'</td><td>'+f2(avgRemainC)+'</td><td>'+avgArr(arrRateAmtC).toFixed(1)+'%</td><td>'+avgArr(arrDepOnlyC).toFixed(1)+'% ('+avgDC.toFixed(1)+'건)</td>'
      +'</tr>';
    th+='</tbody></table>';
    document.getElementById('summaryTable-'+key).innerHTML=th;
  }

  var chartsReady={};
  function switchTab(t){
    ['summary','staff','all','domestic','overseas','appendix'].forEach(function(x){
      var p=document.getElementById('panel-'+x),b=document.getElementById('btn-'+x);
      if(x===t){p.classList.add('is-active');b.classList.add('is-active');}
      else{p.classList.remove('is-active');b.classList.remove('is-active');}
    });
    if(!chartsReady[t] && t!=='appendix' && t!=='summary' && t!=='staff'){initGroup(t);chartsReady[t]=true;}
  }
  window.switchTab=switchTab;

  initGroup('all');
  chartsReady.all=true;
})();
</script>
</body>
</html>
